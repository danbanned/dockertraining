generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 Int               @id @default(autoincrement())
  email              String            @unique @db.VarChar(255)
  passwordHash       String            @map("password_hash") @db.VarChar(255)
  career             String?           @db.VarChar(255)
  incomeGoal         Decimal?          @map("income_goal") @db.Decimal(12, 2)
  cityGoal           String?           @map("city_goal") @db.VarChar(255)
  fitnessGoal        String?           @map("fitness_goal") @db.VarChar(255)
  communicationGoal  String?           @map("communication_goal") @db.VarChar(255)
  createdAt          DateTime          @default(now()) @map("created_at")
  goals              Goal[]
  careerPaths        CareerPath[]
  roadmaps           Roadmap[]
  dailyTasks         DailyTask[]
  jobApplications    JobApplication[]
  progressMetrics    ProgressMetric[]
  aiLogs             AILog[]

  @@map("users")
}

model Goal {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  type      String   @db.VarChar(50)
  target    String
  deadline  DateTime? @db.Date
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model CareerPath {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  title       String?  @db.VarChar(255)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("career_paths")
}

model Roadmap {
  id          Int           @id @default(autoincrement())
  userId      Int           @map("user_id")
  title       String?       @db.VarChar(255)
  startDate   DateTime?     @map("start_date") @db.Date
  endDate     DateTime?     @map("end_date") @db.Date
  description String?
  createdAt   DateTime      @default(now()) @map("created_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  steps       RoadmapStep[]

  @@map("roadmaps")
}

model RoadmapStep {
  id          Int      @id @default(autoincrement())
  roadmapId   Int      @map("roadmap_id")
  month       Int?
  title       String?  @db.VarChar(255)
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id], onDelete: Cascade)

  @@map("roadmap_steps")
}

model DailyTask {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  date       DateTime? @db.Date
  task       String
  category   String?  @db.VarChar(50)
  reason     String?
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("daily_tasks")
}

model JobApplication {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  company     String?  @db.VarChar(255)
  position    String?  @db.VarChar(255)
  dateApplied DateTime? @map("date_applied") @db.Date
  status      String?  @default("Applied") @db.VarChar(50)
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("job_applications")
}

model ProgressMetric {
  id                 Int      @id @default(autoincrement())
  userId             Int      @map("user_id")
  skillsScore        Decimal? @map("skills_score") @db.Decimal(5, 2)
  applicationsScore  Decimal? @map("applications_score") @db.Decimal(5, 2)
  communicationScore Decimal? @map("communication_score") @db.Decimal(5, 2)
  healthScore        Decimal? @map("health_score") @db.Decimal(5, 2)
  environmentScore   Decimal? @map("environment_score") @db.Decimal(5, 2)
  consistencyScore   Decimal? @map("consistency_score") @db.Decimal(5, 2)
  totalScore         Decimal? @map("total_score") @db.Decimal(6, 2)
  date               DateTime @default(now()) @db.Date
  createdAt          DateTime @default(now()) @map("created_at")
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("progress_metrics")
}

model AILog {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  modelUsed  String?  @map("model_used") @db.VarChar(50)
  prompt     String?
  response   String?
  durationMs Int?     @map("duration_ms")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_logs")
}
